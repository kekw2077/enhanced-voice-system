# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
/android/build/

# JVM heap dumps (crash artifacts)
*.hprof

# WinSparkle update signing — the PRIVATE key must never be committed.
# (dsa_pub.pem IS committed: it's embedded via windows/runner/Runner.rc.)
dsa_priv.pem
dsaparam.pem

# Python sidecar build artifacts — rebuilt via sidecar/build_exe.ps1.
# (The frozen evs_sidecar.exe is ~95 MB; the venv is huge. Source stays,
# artifacts don't.)
sidecar/.venv/
sidecar/build/
sidecar/dist/
sidecar/*.spec
**/__pycache__/

# Built installers — shipped as GitHub Release assets, not committed (~110 MB).
dist/out/
